# ===== Database =====
DATABASE_URL=postgresql+asyncpg://autoform:autoform_secret@postgres:5432/autoformfiller
DATABASE_SYNC_URL=postgresql://autoform:autoform_secret@postgres:5432/autoformfiller

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== MinIO / Object Storage =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret_change_in_prod
MINIO_BUCKET=autoformfiller-docs
MINIO_USE_SSL=false

# ===== Security / JWT =====
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_64_chars_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ===== Envelope Encryption =====
# Master Key Encryption Key (KEK) - in production, store in HashiCorp Vault
KEK_BASE64=REPLACE_WITH_32_BYTE_BASE64_ENCODED_KEY
KEK_VAULT_PATH=secret/autoformfiller/kek

# ===== Ollama / LLM =====
OLLAMA_HOST=http://ollama:11434
OLLAMA_PRIMARY_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_TIMEOUT_SECONDS=120

# ===== OCR =====
OCR_LANG=en+hi
OCR_ENGINE=paddleocr

# ===== Embedding Model =====
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

# ===== Celery =====
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== App Settings =====
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ===== Rate Limiting =====
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_UPLOAD=30/hour

# ===== OTP (stub in dev - logs to console) =====
OTP_PROVIDER=console
OTP_TTL_SECONDS=600
