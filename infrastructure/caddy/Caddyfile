{
    # Global options
    email admin@autoformfiller.in
    admin off
}

# Development (HTTP only on localhost)
localhost {
    # API routes → FastAPI backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Health check
    handle /health {
        reverse_proxy backend:8000
    }

    # Metrics (restrict in production)
    handle /metrics {
        reverse_proxy backend:8000
    }

    # All other routes → React frontend
    handle {
        reverse_proxy frontend:5173
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
        format json
    }
}
